)

print("===== LORA CONFIGURATION =====")
print(f" Rank (r) : {peft_config.r}")
print(f" Alpha (?) : {peft_config.lora_alpha}")
print(f" Effective Scaling : {peft_config.lora_alpha / peft_config.r}")
print(f" Dropout : {peft_config.lora_dropout}")
